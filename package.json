{
  "name": "delete-gitea-workflow-runs",
  "version": "1.0.0",
  "description": "Gitea Action to delete workflow runs in a repository.",
  "main": "dist/index.js",
  "private": true,
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "npm run lint",
    "build": "ncc build index.js -o dist --minify",
    "test": "jest",
    "lint": "eslint . --ext .js --no-config-lookup",
    "format": "prettier --print-width 200 --write ./index.js",
    "ci": "npm ci --prefer-offline --no-audit --progress=false"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Soncresity-Industries/delete-gitea-workflow-runs.git"
  },
  "keywords": [
    "gitea",
    "actions",
    "workflow",
    "delete"
  ],
  "author": "Soncresity Industries",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@actions/core": "^2.0.2",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "prettier": "^3.7.4"
  }
}
